# VayuTask AI — local frontend configuration
# Copy to .env.local and adjust as needed:
#   cp .env.local.example .env.local

# REST API base URL (optional for local dev)
# Leave empty to use Next.js rewrites: browser calls /api/* → backend (see next.config.mjs)
# Set when the API runs on another host/port without rewrites, e.g. http://localhost:4000
NEXT_PUBLIC_API_BASE=

# WebSocket base URL (required for /chat and live notifications)
# Must point at the FastAPI server; rewrites do not apply to WebSockets
NEXT_PUBLIC_WS_BASE=ws://localhost:4000

# Backend URL used only by next.config.mjs rewrites (optional override)
NEXT_PUBLIC_API_REWRITE_TARGET=http://localhost:4000
