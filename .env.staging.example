# Staging environment template (copy to .env.staging and load before compose)
# PowerShell: Get-Content .env.staging | ForEach-Object { if ($_ -match '^([^#=]+)=(.*)$') { [Environment]::SetEnvironmentVariable($matches[1], $matches[2]) } }
# Bash: set -a && source .env.staging && set +a

SECRET_KEY=staging-replace-with-long-random-string
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/airtasker

# Lock CORS to your staging frontend origin(s), comma-separated
CORS_ALLOWED_ORIGINS=https://staging.yourdomain.com,http://localhost:3000

# Demo-friendly defaults (enable real Gemini/Razorpay when ready)
USE_MOCK_CHATBOT=true
GEMINI_API_KEY=
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
KYC_REQUIRED_FOR_PAYOUT=true
KYC_STUB_AUTO_VERIFY=true

# Optional Redis (requires --profile cache)
# REDIS_URL=redis://redis:6379/0

ENABLE_PROMETHEUS_METRICS=true

# Closed beta defaults (see beta/SUPPORT_PLAYBOOK.md)
BETA_MODE_ENABLED=true
BETA_CATEGORIES=electrical,plumbing,cleaning
BETA_PIN_CODES=248001,110001,560001
BETA_LANGUAGES=en,hi,ta
