# Copy on Oracle VM: cp deploy/oracle.env.example .env.deploy
# Load before compose: set -a && source .env.deploy && set +a

# --- Required ---
SECRET_KEY=replace-with-openssl-rand-hex-32-output
POSTGRES_PASSWORD=replace-with-strong-db-password
DATABASE_URL=postgresql+asyncpg://postgres:replace-with-strong-db-password@db:5432/airtasker

# Set AFTER Vercel deploy (comma-separated, no spaces after commas)
CORS_ALLOWED_ORIGINS=https://YOUR-APP.vercel.app

ENVIRONMENT=staging
USE_MOCK_CHATBOT=true

# --- Closed beta (defaults OK) ---
BETA_MODE_ENABLED=true
BETA_CATEGORIES=electrical,plumbing,cleaning
BETA_PIN_CODES=248001,110001,560001

# --- Optional: real email OTP (Gmail app password / SendGrid) ---
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=you@gmail.com
# SMTP_PASSWORD=app-password
# EMAIL_FROM=you@gmail.com

# --- Optional: Gemini / Razorpay ---
# GEMINI_API_KEY=
# USE_MOCK_CHATBOT=false
# RAZORPAY_KEY_ID=
# RAZORPAY_KEY_SECRET=
