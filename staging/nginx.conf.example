# Example nginx reverse proxy for staging API (TLS termination).
# Place certificates at /etc/letsencrypt/live/staging-api.example.com/
# Adjust server_name and upstream to match your host.

upstream vayutask_api {
    server 127.0.0.1:4000;
}

server {
    listen 443 ssl http2;
    server_name staging-api.example.com;

    ssl_certificate     /etc/letsencrypt/live/staging-api.example.com/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/staging-api.example.com/privkey.pem;

    client_max_body_size 12m;

    location / {
        proxy_pass http://vayutask_api;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    location /api/notifications/ws {
        proxy_pass http://vayutask_api;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_set_header Host $host;
    }
}

server {
    listen 80;
    server_name staging-api.example.com;
    return 301 https://$host$request_uri;
}
