APP_NAME=airtasker-india-fastapi
ENVIRONMENT=development
PORT=4000
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/airtasker
SECRET_KEY=replace-with-a-long-random-secret
ACCESS_TOKEN_EXPIRE_MINUTES=1440
JWT_ALGORITHM=HS256
USE_MOCK_CHATBOT=true
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
PINECONE_API_KEY=
PINECONE_INDEX=
PINECONE_NAMESPACE=airtasker-help

# Optional: Redis cache + cross-worker notification WebSocket fanout (pub/sub channel `airtasker:notifications`)
REDIS_URL=

# Razorpay (optional — real orders + webhooks)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
# RazorpayX business account number (Dashboard) — required for POST /v1/payouts to taskers
RAZORPAY_PAYOUT_ACCOUNT_NUMBER=
RAZORPAY_WEBHOOK_SECRET=
# Webhook dedupe table retention (scheduled delete); set interval 0 to disable cleanup loop
RAZORPAY_WEBHOOK_EVENTS_RETENTION_DAYS=90
RAZORPAY_WEBHOOK_EVENTS_CLEANUP_INTERVAL_HOURS=24

# KYC (stub). Set KYC_STUB_AUTO_VERIFY=false to require admin approval for each submission.
KYC_PROVIDER=stub
KYC_STUB_AUTO_VERIFY=true
# Optional HMAC (hex) for POST /api/webhooks/kyc — same pattern as Razorpay webhook signing
KYC_WEBHOOK_SECRET=
# Require verified KYC for Razorpay payout bank registration and automatic escrow payouts to taskers
KYC_REQUIRED_FOR_PAYOUT=false
